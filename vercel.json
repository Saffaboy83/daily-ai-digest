{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/digest.ts": {
      "memory": 512,
      "maxDuration": 60,
      "includeFiles": "api/_lib/**"
    },
    "api/upload-media.ts": {
      "memory": 512,
      "maxDuration": 60,
      "includeFiles": "api/_lib/**"
    },
    "api/**/*.ts": {
      "memory": 256,
      "maxDuration": 30,
      "includeFiles": "api/_lib/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
